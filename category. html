        </section>

        <!-- ===== ACADEMY MESSAGES ===== -->
        <section class="section-block" style="padding-bottom:100px;">
            <h2 class="section-title">رسائل الأكاديمية</h2>
            <div id="messagesList"></div>
        </section>
