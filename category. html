    <script>
        // ============================================================
        // CONFIG
        // ============================================================
        const DB_URL = 'https://academy-chelghoum-el-aide-default-rtdb.firebaseio.com/';
        const LOGO_URL = 'https://github.com/darkonovic51-hash/Academy-CHELGHOUM-LAID/blob/375f8eeeb142420ea9e8d4682208f3a33825ef7b/1783696246097.jpg?raw=true';
        const params = new URLSearchParams(window.location.search);
        const CATEGORY = params.get('cat') || 'U7';

        const ageLabels = { U7:'براعم', U9:'صغار', U11:'ناشئين', U13:'أشبال', U15:'فتيان', U17:'شباب', U19:'أولمبي' };
        const statusLabels = { active: 'نشيط', injured: 'مصاب', suspended: 'موقوف' };
        const msgTypeIcons = { 'إعلان':'fa-bullhorn','تنبيه':'fa-triangle-exclamation','اجتماع':'fa-people-group','إشعار':'fa-bell','تهنئة':'fa-award','تعليق':'fa-comment' };

        // بيانات احتياطية بسيطة لو النود فاضي أو فشل الاتصال
        const FALLBACK = {
            players: [
                { name: 'أحمد زروقي', number: 10, position: 'وسط', birthYear: 2011, status: 'active', photoUrl: '', category: CATEGORY },
                { name: 'ياسين بن عمر', number: 7, position: 'مهاجم', birthYear: 2011, status: 'injured', photoUrl: '', category: CATEGORY }
            ],
            sessions: [
                { name: 'حصة تقنية', day: 'الأحد', date: '2026-07-20', time: '17:00', field: 'الملعب الرئيسي', coach: 'كريم عبدي', status: 'scheduled', category: CATEGORY }
            ],
            matches: [],
            tournaments: [],
            messages: []
        };

        // ============================================================
        // FIREBASE REST HELPER
        // ============================================================
        async function fetchNode(node, fallback) {
            try {
                const res = await fetch(`${DB_URL}${node}.json`);
                if (!res.ok) throw new Error('bad response');
                const data = await res.json();
                if (!data) return fallback;
                return Array.isArray(data) ? data.filter(Boolean) : Object.values(data);
            } catch (err) {
                console.warn(`تعذّرت قراءة "${node}"، استخدام بيانات احتياطية.`, err);
                return fallback;
            }
        }
        function byCategory(list) {
            return list.filter(item => item.category === CATEGORY);
        }

        // ============================================================
        // TICKER
        // ============================================================
        function renderTicker(news) {
            const ticker = document.getElementById('ticker');
            const items = [...news, ...news];
            ticker.innerHTML = items.map(n => `
                <span class="ticker-item">
                    <span class="dot"></span>${n.text}
                    <img class="separator-logo" src="${LOGO_URL}" onerror="this.style.display='none'" />
                </span>`).join('');
        }

        // ============================================================
        // PLAYERS TABLE STATE
        // ============================================================
        let allPlayers = [];
        let filteredPlayers = [];
        let sortKey = null, sortAsc = true;
        let currentPage = 1;
        const PAGE_SIZE = 8;

        function applyFilters() {
            const search = document.getElementById('searchInput').value.trim().toLowerCase();
            const pos = document.getElementById('positionFilter').value;
            const stat = document.getElementById('statusFilter').value;
            filteredPlayers = allPlayers.filter(p => {
                const matchSearch = !search || (p.name || '').toLowerCase().includes(search);
                const matchPos = !pos || p.position === pos;
                const matchStat = !stat || p.status === stat;
                return matchSearch && matchPos && matchStat;
            });
            if (sortKey) {
                filteredPlayers.sort((a, b) => {
                    let va = a[sortKey] ?? '', vb = b[sortKey] ?? '';
                    if (typeof va === 'string') va = va.toLowerCase();
                    if (typeof vb === 'string') vb = vb.toLowerCase();
                    if (va < vb) return sortAsc ? -1 : 1;
                    if (va > vb) return sortAsc ? 1 : -1;
                    return 0;
                });
            }
            currentPage = 1;
            renderTable();
        }

        function renderTable() {
            const tbody = document.getElementById('playersTableBody');
            const noResults = document.getElementById('noResults');
            const start = (currentPage - 1) * PAGE_SIZE;
            const pageItems = filteredPlayers.slice(start, start + PAGE_SIZE);

            if (filteredPlayers.length === 0) {
                tbody.innerHTML = '';
                noResults.style.display = 'block';
            } else {
                noResults.style.display = 'none';
                tbody.innerHTML = pageItems.map(p => `
                    <tr>
                        <td><img class="p-photo" src="${p.photoUrl || ''}" onerror="this.style.visibility='hidden'" /></td>
                        <td>${p.name || '-'}</td>
                        <td>${p.birthYear || '-'}</td>
                        <td>${p.position || '-'}</td>
                        <td>${p.number ?? '-'}</td>
                        <td><span class="status-badge ${p.status || 'active'}">${statusLabels[p.status] || 'نشيط'}</span></td>
                    </tr>
                `).join('');
            }
            renderPagination();
        }

        function renderPagination() {
            const wrap = document.getElementById('pagination');
            const totalPages = Math.ceil(filteredPlayers.length / PAGE_SIZE);
            if (totalPages <= 1) { wrap.innerHTML = ''; return; }
            let html = '';
            for (let i = 1; i <= totalPages; i++) {
                html += `<button class="${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
            }
            wrap.innerHTML = html;
            wrap.querySelectorAll('button').forEach(btn => {
                btn.addEventListener('click', () => {
                    currentPage = parseInt(btn.dataset.page, 10);
                    renderTable();
                });
            });
        }

        document.getElementById('searchInput').addEventListener('input', applyFilters);
        document.getElementById('positionFilter').addEventListener('change', applyFilters);
        document.getElementById('statusFilter').addEventListener('change', applyFilters);

        document.querySelectorAll('table.players-table th[data-sort]').forEach(th => {
            th.addEventListener('click', () => {
                const key = th.dataset.sort;
                if (key === 'photo') return;
                if (sortKey === key) { sortAsc = !sortAsc; } else { sortKey = key; sortAsc = true; }
                applyFilters();
            });
        });

        // ===== EXPORT =====
        document.getElementById('exportExcelBtn').addEventListener('click', () => {
            const rows = filteredPlayers.map(p => ({
                'الاسم': p.name || '', 'سنة الميلاد': p.birthYear || '', 'المركز': p.position || '',
                'الرقم': p.number ?? '', 'الحالة': statusLabels[p.status] || 'نشيط'
            }));
            const ws = XLSX.utils.json_to_sheet(rows);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, CATEGORY);
            XLSX.writeFile(wb, `لاعبين_${CATEGORY}.xlsx`);
        });

        document.getElementById('exportPdfBtn').addEventListener('click', () => {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.autoTable({
                head: [['الحالة', 'الرقم', 'المركز', 'سنة الميلاد', 'الاسم']],
                body: filteredPlayers.map(p => [
                    statusLabels[p.status] || 'نشيط', p.number ?? '', p.position || '', p.birthYear || '', p.name || ''
                ]),
                styles: { font: 'helvetica', halign: 'center' },
                headStyles: { fillColor: [14, 72, 50] }
            });
            doc.save(`لاعبين_${CATEGORY}.pdf`);
        });

        // ============================================================
        // SESSIONS / MATCHES / TOURNAMENTS / MESSAGES
        // ============================================================
        const sessionStatusLabels = { scheduled: 'مجدولة', finished: 'منتهية', canceled: 'ملغاة' };
        function renderSessions(sessions) {
            const grid = document.getElementById('sessionsGrid');
            if (!sessions.length) { grid.innerHTML = '<div class="empty-state">لا توجد حصص مجدولة حاليًا لهذه الفئة.</div>'; return; }
            grid.innerHTML = sessions.map(s => `
                <div class="session-card">
                    <h4>${s.name || 'حصة تدريبية'}</h4>
                    <div class="row"><i class="fas fa-calendar-day"></i> ${s.day || ''} - ${s.date || ''}</div>
                    <div class="row"><i class="fas fa-clock"></i> ${s.time || ''}</div>
                    <div class="row"><i class="fas fa-map-marker-alt"></i> ${s.field || ''}</div>
                    <div class="row"><i class="fas fa-user-tie"></i> ${s.coach || ''}</div>
                    <div class="status-line"><span class="status-badge active">${sessionStatusLabels[s.status] || 'مجدولة'}</span></div>
                </div>
            `).join('');
        }

        function renderMatches(matches) {
            const grid = document.getElementById('matchesGrid');
            if (!matches.length) { grid.innerHTML = '<div class="empty-state">لا توجد مباريات مسجلة حاليًا لهذه الفئة.</div>'; return; }
            grid.innerHTML = matches.map(m => `
                <div class="match-card">
                    <span class="status-tag ${m.status || 'upcoming'}">${{upcoming:'قادمة',finished:'انتهت',canceled:'ملغاة'}[m.status] || 'قادمة'}</span>
                    <div class="match-top">
                        <div class="team"><img src="${m.homeLogo || LOGO_URL}" onerror="this.style.visibility='hidden'" /><span>الأكاديمية</span></div>
                        <div class="vs">${m.status === 'finished' && m.result ? `<span class="score">${m.result}</span>` : 'VS'}</div>
                        <div class="team"><img src="${m.opponentLogo || ''}" onerror="this.style.visibility='hidden'" /><span>${m.opponent || 'الفريق المنافس'}</span></div>
                    </div>
                    <div class="match-meta">
                        <span><i class="fas fa-calendar-day"></i> ${m.date || ''}</span>
                        <span><i class="fas fa-clock"></i> ${m.time || ''}</span>
                        <span><i class="fas fa-map-marker-alt"></i> ${m.field || ''}</span>
                        <span><i class="fas fa-tag"></i> ${m.type || ''}</span>
                    </div>
                    ${m.details ? `<a class="details-btn" href="${m.details}">عرض التفاصيل ←</a>` : ''}
                </div>
            `).join('');
        }

        function renderTournaments(tournaments) {
            const grid = document.getElementById('tournamentsGrid');
            if (!tournaments.length) { grid.innerHTML = '<div class="empty-state">الفئة غير مشاركة في أي بطولة حاليًا.</div>'; return; }
            grid.innerHTML = tournaments.map(t => `
                <div class="tournament-card">
                    <div class="t-head">
                        <img src="${t.logo || LOGO_URL}" onerror="this.style.visibility='hidden'" />
                        <h4>${t.name || 'بطولة'}</h4>
                    </div>
                    <div class="t-body">
                        <div class="row"><i class="fas fa-user-tie"></i> المنظم: ${t.organizer || '-'}</div>
                        <div class="row"><i class="fas fa-map-marker-alt"></i> ${t.place || '-'}</div>
                        <div class="row"><i class="fas fa-calendar"></i> ${t.date || ''} ${t.period ? `(${t.period})` : ''}</div>
                        <div class="row"><i class="fas fa-users"></i> عدد الفرق: ${t.teamsCount || '-'}</div>
                        ${t.standings ? `<div class="row"><i class="fas fa-list-ol"></i> ${t.standings}</div>` : ''}
                        ${t.files ? `<a class="files-link" href="${t.files}" target="_blank"><i class="fas fa-paperclip"></i> الملفات المرفقة</a>` : ''}
                    </div>
                </div>
            `).join('');
        }

        function renderMessages(messages) {
            const list = document.getElementById('messagesList');
            if (!messages.length) { list.innerHTML = '<div class="empty-state">لا توجد رسائل جديدة من إدارة الأكاديمية.</div>'; return; }
            const sorted = [...messages].sort((a, b) => new Date(b.date || 0) - new Date(a.date || 0));
            list.innerHTML = sorted.map(m => `
                <div class="msg-card">
                    <div class="msg-icon"><i class="fas ${msgTypeIcons[m.type] || 'fa-comment-dots'}"></i></div>
                    <div>
                        <div class="msg-type">${m.type || 'رسالة'}</div>
                        <p class="msg-text">${m.text || ''}</p>
                        ${m.date ? `<div class="msg-date">${m.date}</div>` : ''}
                    </div>
                </div>
            `).join('');
        }

        // ============================================================
        // BANNER + STATS
        // ============================================================
        function renderBanner(playersCount, sessionsCount, matchesCount) {
            document.getElementById('catTag').textContent = 'فئة عمرية';
            document.getElementById('catTitle').textContent = CATEGORY;
            document.getElementById('catSubLabel').textContent = ageLabels[CATEGORY] || 'فئة';
            document.getElementById('statPlayers').textContent = playersCount;
            document.getElementById('statSessions').textContent = sessionsCount;
            document.getElementById('statMatches').textContent = matchesCount;
            document.title = `فئة ${CATEGORY} | ETOILE CHELGHOUM LAID ACADEMY`;
        }

        // ============================================================
        // INIT
        // ============================================================
        (async function init() {
            const [players, sessions, matches, tournaments, messages, news] = await Promise.all([
                fetchNode('players', FALLBACK.players),
                fetchNode('sessions', FALLBACK.sessions),
                fetchNode('matches', FALLBACK.matches),
                fetchNode('tournaments', FALLBACK.tournaments),
                fetchNode('messages', FALLBACK.messages),
                fetchNode('news', [{ text: '✧ افتتاح التسجيلات للموسم الجديد 2026-2027' }])
            ]);

            allPlayers = byCategory(players);
            const catSessions = byCategory(sessions);
            const catMatches = byCategory(matches);
            const catTournaments = byCategory(tournaments);
            const catMessages = byCategory(messages);

            renderBanner(allPlayers.length, catSessions.filter(s => s.status !== 'finished').length, catMatches.length);
            applyFilters();
            renderSessions(catSessions);
            renderMatches(catMatches);
            renderTournaments(catTournaments);
            renderMessages(catMessages);
            renderTicker(news);

            console.log(`✅ صفحة الفئة ${CATEGORY} جاهزة.`);
        })();
    </script>
</body>
</html>
