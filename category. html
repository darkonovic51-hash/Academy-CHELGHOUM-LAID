    <!-- ===== CATEGORY BANNER ===== -->
    <section class="cat-banner">
        <div class="cat-banner-content">
            <span class="cat-tag" id="catTag">فئة</span>
            <h1 id="catTitle">U--</h1>
            <p class="sub" id="catSubLabel">فئة عمرية</p>
            <div class="stats-row">
