                    </select>
                </div>
                <div class="toolbar-right">
                    <button class="export-btn pdf" id="exportPdfBtn"><i class="fas fa-file-pdf"></i> PDF</button>
                    <button class="export-btn excel" id="exportExcelBtn"><i class="fas fa-file-excel"></i> Excel</button>
                </div>
            </div>
            <div class="players-table-wrap">
                <table class="players-table">
                    <thead>
