                            <th data-sort="birthYear">سنة الميلاد <i class="fas fa-sort"></i></th>
                            <th data-sort="position">المركز <i class="fas fa-sort"></i></th>
                            <th data-sort="number">الرقم <i class="fas fa-sort"></i></th>
