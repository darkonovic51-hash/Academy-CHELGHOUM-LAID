<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>صفحة الفئة | ETOILE CHELGHOUM LAID ACADEMY</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"/>
    <!-- مكتبات التصدير -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
    <style>
        :root {
            --primary-dark: #0E4832;
            --primary-mid: #136F46;
            --red-accent: #C8102E;
            --black: #1A1A1A;
            --white: #F2F2F2;
            --gold: #D4AF37;
            --gold-light: #F3DFA0;
            --shadow-heavy: 0 20px 60px rgba(0, 0, 0, 0.4);
            --shadow-soft: 0 8px 32px rgba(0, 0, 0, 0.08);
            --shadow-medium: 0 12px 40px rgba(0, 0, 0, 0.15);
            --ticker-height: 42px;
            --navbar-height: 78px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Cairo', sans-serif;
            background: #f8f8f8;
            color: var(--black);
            direction: rtl;
            line-height: 1.7;
            overflow-x: hidden;
            padding-top: calc(var(--ticker-height) + var(--navbar-height));
        }
        a { text-decoration: none; color: inherit; }
        img { max-width: 100%; display: block; }
        .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
        h1, h2, h3, .bebas {
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }
        .section-title {
            font-size: 2.4rem;
            font-family: 'Bebas Neue', sans-serif;
            letter-spacing: 2px;
            position: relative;
            display: inline-block;
            margin-bottom: 30px;
            color: var(--primary-dark);
        }
        .section-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            right: 0;
            width: 70px;
            height: 4px;
            background: var(--red-accent);
            border-radius: 4px;
        }
        .section-block { padding: 60px 0; }
        .section-block.alt { background: var(--white); }

        /* ===== TICKER (نفس هوية الرئيسية) ===== */
        .ticker-wrap {
            position: fixed; top: 0; left: 0; width: 100%; height: var(--ticker-height);
            z-index: 1001; background: linear-gradient(90deg, var(--gold-light) 0%, var(--gold) 100%);
            border-bottom: 2px solid var(--primary-dark); overflow: hidden; display: flex; align-items: center;
        }
        .ticker { display: flex; align-items: center; gap: 40px; animation: tickerScroll 32s linear infinite; white-space: nowrap; width: max-content; }
        .ticker-item { display: flex; align-items: center; gap: 14px; color: var(--primary-dark); font-weight: 700; font-size: 0.92rem; }
        .ticker-item .dot { width: 7px; height: 7px; background: var(--red-accent); border-radius: 50%; animation: pulseDot 1.6s ease-in-out infinite; }
        .ticker-item .separator-logo { width: 20px; height: 20px; border-radius: 50%; object-fit: contain; background: var(--white); padding: 2px; margin: 0 10px; }
        @keyframes tickerScroll { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }
        @keyframes pulseDot { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.85); } }

        /* ===== NAVBAR (مبسّطة لصفحة داخلية) ===== */
        .navbar {
            position: fixed; top: var(--ticker-height); left: 0; width: 100%; z-index: 999;
            background: rgba(14, 72, 50, 0.95); backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255,255,255,0.08); padding: 14px 0;
        }
        .navbar .container { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
        .navbar .logo-link { display: flex; align-items: center; gap: 10px; color: var(--white); font-family: 'Bebas Neue'; font-size: 1.3rem; letter-spacing: 2px; }
        .navbar .logo-link img { width: 42px; height: 42px; border-radius: 50%; background: var(--white); padding: 2px; }
        .navbar .back-link { color: rgba(255,255,255,0.85); font-weight: 600; font-size: 0.9rem; display: flex; align-items: center; gap: 8px; transition: 0.3s; }
        .navbar .back-link:hover { color: var(--gold); }

        /* ===== CATEGORY BANNER ===== */
        .cat-banner {
            position: relative; min-height: 46vh; display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary-mid) 100%);
            overflow: hidden; text-align: center; color: var(--white);
        }
        .cat-banner::before {
            content: ''; position: absolute; right: -60px; top: -80px; width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(212,175,55,0.15), transparent 70%);
        }
        .cat-banner-content { position: relative; z-index: 2; padding: 30px 20px; }
        .cat-banner .cat-tag {
            display: inline-block; background: rgba(255,255,255,0.1); border: 1px solid var(--gold);
            padding: 6px 24px; border-radius: 40px; font-size: 0.9rem; letter-spacing: 2px; margin-bottom: 16px;
        }
        .cat-banner h1 { font-size: clamp(3rem, 10vw, 6rem); text-shadow: 0 8px 30px rgba(0,0,0,0.4); }
        .cat-banner .sub { font-size: 1.2rem; font-weight: 300; color: rgba(255,255,255,0.85); margin-top: 8px; }
        .cat-banner .stats-row { display: flex; gap: 30px; justify-content: center; margin-top: 24px; flex-wrap: wrap; }
        .cat-banner .stat-pill {
            background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);
            padding: 10px 22px; border-radius: 40px; font-size: 0.9rem;
        }
        .cat-banner .stat-pill b { color: var(--gold); font-family: 'Bebas Neue'; font-size: 1.1rem; margin-left: 6px; }

        /* ===== PLAYERS TABLE ===== */
        .table-toolbar {
            display: flex; flex-wrap: wrap; gap: 14px; align-items: center; justify-content: space-between;
            margin-bottom: 20px; background: var(--white); padding: 18px; border-radius: 20px; box-shadow: var(--shadow-soft);
        }
        .toolbar-left, .toolbar-right { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
        .table-toolbar input[type="text"], .table-toolbar select {
            padding: 10px 16px; border-radius: 40px; border: 1px solid #ddd; font-family: 'Cairo'; font-size: 0.9rem;
            background: #fafafa; transition: 0.3s;
        }
        .table-toolbar input:focus, .table-toolbar select:focus { outline: none; border-color: var(--primary-mid); }
        .export-btn {
            display: flex; align-items: center; gap: 8px; padding: 10px 18px; border-radius: 40px; border: none;
            font-weight: 700; font-size: 0.85rem; cursor: pointer; transition: 0.3s; color: var(--white);
        }
        .export-btn.pdf { background: var(--red-accent); }
        .export-btn.pdf:hover { background: #a00d24; transform: translateY(-2px); }
        .export-btn.excel { background: #1D6F42; }
        .export-btn.excel:hover { background: #14512f; transform: translateY(-2px); }

        .players-table-wrap { background: var(--white); border-radius: 24px; box-shadow: var(--shadow-soft); overflow: hidden; }
        table.players-table { width: 100%; border-collapse: collapse; }
        table.players-table thead { background: var(--primary-dark); color: var(--white); }
        table.players-table th {
            padding: 16px 14px; font-family: 'Bebas Neue'; letter-spacing: 1px; font-size: 1rem;
            text-align: center; cursor: pointer; user-select: none; white-space: nowrap;
        }
        table.players-table th i { margin-right: 6px; font-size: 0.75rem; opacity: 0.6; }
        table.players-table td { padding: 12px 14px; text-align: center; border-bottom: 1px solid #eee; font-size: 0.92rem; }
        table.players-table tbody tr { transition: 0.25s; }
        table.players-table tbody tr:hover { background: #f4faf6; }
        table.players-table .p-photo {
            width: 44px; height: 44px; border-radius: 50%; object-fit: cover; margin: 0 auto;
            border: 2px solid var(--gold);
        }
        .status-badge { padding: 4px 14px; border-radius: 30px; font-size: 0.78rem; font-weight: 700; }
        .status-badge.active { background: #E1F6EA; color: #1D8348; }
        .status-badge.injured { background: #FDEAEA; color: var(--red-accent); }
        .status-badge.suspended { background: #FFF3D6; color: #B8860B; }
        .no-results { text-align: center; padding: 40px; color: #999; }

        .pagination { display: flex; justify-content: center; gap: 8px; padding: 20px; flex-wrap: wrap; }
        .pagination button {
            width: 36px; height: 36px; border-radius: 50%; border: 1px solid #ddd; background: var(--white);
            cursor: pointer; font-weight: 700; transition: 0.25s; font-family: 'Cairo';
        }
        .pagination button.active { background: var(--primary-mid); color: var(--white); border-color: var(--primary-mid); }
        .pagination button:hover:not(.active) { background: #f0f0f0; }

        /* ===== SESSIONS / MATCHES / TOURNAMENTS CARDS ===== */
        .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }

        .session-card {
            background: var(--white); border-radius: 22px; box-shadow: var(--shadow-soft); overflow: hidden;
            border-right: 5px solid var(--primary-mid); transition: 0.3s; padding: 20px;
        }
        .session-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-medium); }
        .session-card h4 { font-size: 1.15rem; color: var(--primary-dark); margin-bottom: 10px; font-family: 'Cairo'; font-weight: 700; }
        .session-card .row { display: flex; align-items: center; gap: 8px; font-size: 0.88rem; color: #555; margin-bottom: 6px; }
        .session-card .row i { color: var(--red-accent); width: 16px; }
        .session-card .status-line { margin-top: 12px; }

        .match-card {
            background: linear-gradient(135deg, var(--primary-dark), #0a3325); border-radius: 22px; overflow: hidden;
            box-shadow: var(--shadow-soft); color: var(--white); transition: 0.35s; position: relative;
        }
        .match-card:hover { transform: translateY(-8px); box-shadow: var(--shadow-heavy); }
        .match-card .match-top { display: flex; align-items: center; justify-content: space-between; padding: 20px; }
        .match-card .team { display: flex; flex-direction: column; align-items: center; gap: 8px; flex: 1; }
        .match-card .team img { width: 52px; height: 52px; object-fit: contain; background: var(--white); border-radius: 50%; padding: 4px; }
        .match-card .team span { font-size: 0.85rem; font-weight: 700; }
        .match-card .vs { font-family: 'Bebas Neue'; font-size: 1.5rem; color: var(--gold); }
        .match-card .score { font-family: 'Bebas Neue'; font-size: 2rem; color: var(--white); }
        .match-card .match-meta { background: rgba(0,0,0,0.25); padding: 12px 20px; display: flex; flex-wrap: wrap; gap: 12px; font-size: 0.8rem; }
        .match-card .match-meta span { display: flex; align-items: center; gap: 6px; color: rgba(255,255,255,0.8); }
        .match-card .status-tag {
            position: absolute; top: 14px; left: 14px; padding: 4px 14px; border-radius: 30px; font-size: 0.72rem; font-weight: 700;
        }
        .status-tag.upcoming { background: var(--gold); color: var(--black); }
        .status-tag.finished { background: #444; color: var(--white); }
        .status-tag.canceled { background: var(--red-accent); color: var(--white); }
        .match-card .details-btn {
            display: block; text-align: center; padding: 10px; background: rgba(255,255,255,0.06);
            font-size: 0.85rem; font-weight: 700; color: var(--gold); border-top: 1px solid rgba(255,255,255,0.1);
            transition: 0.3s;
        }
        .match-card .details-btn:hover { background: rgba(255,255,255,0.12); }

        .tournament-card {
            background: var(--white); border-radius: 22px; box-shadow: var(--shadow-soft); overflow: hidden; transition: 0.3s;
        }
        .tournament-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-medium); }
        .tournament-card .t-head { display: flex; align-items: center; gap: 14px; padding: 18px; background: var(--primary-dark); color: var(--white); }
        .tournament-card .t-head img { width: 50px; height: 50px; object-fit: contain; background: var(--white); border-radius: 50%; padding: 4px; }
        .tournament-card .t-head h4 { font-family: 'Bebas Neue'; font-size: 1.2rem; letter-spacing: 1px; }
        .tournament-card .t-body { padding: 18px; font-size: 0.88rem; color: #555; }
        .tournament-card .t-body .row { display: flex; gap: 8px; margin-bottom: 8px; align-items: center; }
        .tournament-card .t-body .row i { color: var(--red-accent); width: 16px; }
        .tournament-card .files-link { display: inline-block; margin-top: 8px; color: var(--primary-mid); font-weight: 700; font-size: 0.85rem; }

        /* ===== MESSAGES ===== */
        .msg-card {
            background: var(--white); border-radius: 18px; box-shadow: var(--shadow-soft); padding: 18px 22px;
            display: flex; gap: 16px; align-items: flex-start; border-right: 4px solid var(--gold); margin-bottom: 16px;
        }
        .msg-card .msg-icon {
            width: 42px; height: 42px; border-radius: 50%; background: var(--primary-dark); color: var(--white);
            display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.1rem;
        }
        .msg-card .msg-type { font-weight: 700; color: var(--primary-dark); font-size: 0.85rem; margin-bottom: 4px; }
        .msg-card .msg-date { color: #999; font-size: 0.78rem; margin-top: 6px; }
        .msg-card p.msg-text { color: #444; font-size: 0.92rem; }

        .empty-state { text-align: center; padding: 40px; color: #999; background: var(--white); border-radius: 20px; }

        @media (max-width: 768px) {
            .cat-banner { min-height: 34vh; }
            table.players-table { font-size: 0.8rem; }
            table.players-table th, table.players-table td { padding: 8px 6px; }
            .players-table-wrap { overflow-x: auto; }
            table.players-table { min-width: 720px; }
        }
    </style>
</head>
<body>
    <!-- ===== TICKER (يقرأ نفس أخبار الرئيسية) ===== -->
    <div class="ticker-wrap"><div class="ticker" id="ticker"></div></div>

    <!-- ===== NAVBAR مبسّطة ===== -->
    <nav class="navbar">
        <div class="container">
            <a href="index.html" class="logo-link">
                <img src="https://github.com/darkonovic51-hash/Academy-CHELGHOUM-LAID/blob/375f8eeeb142420ea9e8d4682208f3a33825ef7b/1783696246097.jpg?raw=true" alt="logo" onerror="this.style.display='none'" />
                <span>ETOILE CHELGHOUM LAID</span>
            </a>
            <a href="index.html" class="back-link"><i class="fas fa-arrow-right"></i> العودة للرئيسية</a>
